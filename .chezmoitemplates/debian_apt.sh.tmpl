#!/bin/bash

set -euo pipefail
echo "Installing packages..."
# Access the packages from .chezmoidata
{{ $aptPackages := .packages.debian.apt }}
{{ if $aptPackages }}
echo "Updating package lists..."
sudo apt update -y # Add -y for non-interactive update

echo "Installing the following packages: {{ join " " $aptPackages }}"
sudo apt install -y {{ join " " $aptPackages }}
{{ else }}
echo "No Debian APT packages defined in .chezmoidata/packages.yaml. Skipping installation."
{{ end }}
echo "Package installation script finished."

